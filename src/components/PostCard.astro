---
import type { Post } from "../lib/posts";
import { getPostPath, getPostPublicationDate, getPostPublicationDateValue } from "../lib/posts";
import { getPostSocialImagePath } from "../lib/social-images";
import { getPrimaryTopic, getTopicPath } from "../data/topics";
import { localeDefinitions } from "../i18n/locales";
import { getPostCardUiCopy } from "../i18n/ui";

interface Props
{
  readonly post: Post;
  readonly alternatePosts?: readonly Post[];
  readonly featured?: boolean;
}

const { post, alternatePosts = [], featured = false } = Astro.props;
const language = post.data.language;
const postPath = getPostPath(post);
const topic = getPrimaryTopic(post);
const imagePath = post.data.featuredImage ?? getPostSocialImagePath(post);
const copy = getPostCardUiCopy(language);
const translations = [post, ...alternatePosts].sort((left, right) => left.data.language.localeCompare(right.data.language));
const publicationDate = getPostPublicationDate(post);
---

<article class:list={["post-card", { "post-card--featured": featured }]} lang={language}>
  <a class="post-card__media" href={postPath} aria-label={`${copy.read}: ${post.data.title}`}>
    <img
      src={imagePath}
      alt=""
      width="1200"
      height="750"
      loading={featured ? "eager" : "lazy"}
      fetchpriority={featured ? "high" : "auto"}
      decoding="async"
    />
    <span class="post-card__index" aria-hidden="true">{publicationDate.getUTCFullYear()}</span>
  </a>
  <div class="post-card__body">
    <div class="post-card__meta">
      <a class="post-card__topic" href={getTopicPath(topic, language)}>{topic.labels[language]}</a>
      <time datetime={getPostPublicationDateValue(post)}>
        {publicationDate.toLocaleDateString(language, { day: "2-digit", month: "short", year: "numeric", timeZone: "UTC" })}
      </time>
      {translations.length > 1 && (
        <nav class="post-card__languages" aria-label={copy.translations}>
          {translations.map((translation, index) => <>
            {index > 0 && <span aria-hidden="true">/</span>}
            <a
              href={getPostPath(translation)}
              lang={translation.data.language}
              hreflang={translation.data.language}
              data-locale={translation.data.language}
              aria-current={translation.data.language === language ? "page" : undefined}
            >{localeDefinitions[translation.data.language].shortName}</a>
          </>)}
        </nav>
      )}
    </div>
    <h2><a href={postPath}>{post.data.title}</a></h2>
    <p>{post.data.description}</p>
    <a class="post-card__read" href={postPath}>{copy.read}<span aria-hidden="true">→</span></a>
  </div>
</article>
