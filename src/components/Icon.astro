---
interface Props
{
  readonly name: "arrow" | "code" | "facebook" | "github" | "globe" | "instagram" | "linkedin" | "mail" | "medium" | "profile" | "rss" | "x";
  readonly label?: string;
}

const { name, label } = Astro.props;
---

<svg class="icon" viewBox="0 0 24 24" role={label ? "img" : undefined} aria-label={label} aria-hidden={label ? undefined : "true"} focusable="false">
  {name === "arrow" && <path d="M7 17 17 7M8 7h9v9" />}
  {name === "code" && <><path d="m8 8-4 4 4 4M16 8l4 4-4 4M14 5l-4 14" /></>}
  {name === "github" && <><circle cx="6" cy="6" r="2" /><circle cx="18" cy="6" r="2" /><circle cx="12" cy="18" r="2" /><path d="M8 6h4a4 4 0 0 1 4 4v1M12 16v-3a3 3 0 0 0-3-3H6" /></>}
  {name === "linkedin" && <><rect x="3" y="3" width="18" height="18" rx="3" /><path d="M8 10v7M8 7.2v.1M12 17v-7m0 3c.8-2 5-2.2 5 1v3" /></>}
  {name === "mail" && <><rect x="3" y="5" width="18" height="14" rx="2" /><path d="m4 7 8 6 8-6" /></>}
  {name === "medium" && <><path d="M4 7v10M7 7l5 10 5-10M20 7v10" /></>}
  {name === "instagram" && <><rect x="3" y="3" width="18" height="18" rx="5" /><circle cx="12" cy="12" r="4" /><path d="M17.5 6.5h.01" /></>}
  {name === "facebook" && <path d="M14.5 21v-8h3l.5-4h-3.5V7c0-1.2.4-2 2.2-2H19V1.5c-.7-.1-1.8-.2-3-.2-3 0-5 1.8-5 5.2V9H8v4h3v8" />}
  {name === "x" && <path d="M5 4 19 20M19 4 5 20" />}
  {name === "rss" && <><circle cx="5" cy="19" r="1.5" fill="currentColor" stroke="none" /><path d="M4 11a9 9 0 0 1 9 9M4 5a15 15 0 0 1 15 15" /></>}
  {name === "globe" && <><circle cx="12" cy="12" r="9" /><path d="M3 12h18M12 3c3 3.2 3 14.8 0 18M12 3c-3 3.2-3 14.8 0 18" /></>}
  {name === "profile" && <><ellipse cx="12" cy="12" rx="9" ry="3.8" transform="rotate(24 12 12)" /><ellipse cx="12" cy="12" rx="9" ry="3.8" transform="rotate(84 12 12)" /><path d="m12 7 1.5 3.5L17 12l-3.5 1.5L12 17l-1.5-3.5L7 12l3.5-1.5Z" fill="currentColor" stroke="none" /></>}
</svg>
