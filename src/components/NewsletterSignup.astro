---
import type { Locale } from "../i18n/locales";
import { getNewsletterUiCopy } from "../i18n/ui";
import {
  newsletterConsentVersion,
  type NewsletterSource,
} from "../worker/newsletter/contracts";

interface Props
{
  readonly language: Locale;
  readonly source: Extract<NewsletterSource, "home" | "article" | "newsletter_page">;
  readonly compact?: boolean;
  readonly panel?: boolean;
}

const { language, source, compact = false, panel = false } = Astro.props;
const copy = getNewsletterUiCopy(language);
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "0x4AAAAAADz2PsYYikXzdz0C";
---

<section
  id="newsletter"
  class:list={["newsletter-signup", { "newsletter-signup--compact": compact, "newsletter-signup--panel": panel }]}
  data-newsletter-root
  data-locale={language}
  data-source={source}
  data-consent-version={newsletterConsentVersion}
  data-copy={JSON.stringify(copy)}
  aria-labelledby={`newsletter-title-${source}`}
>
  <header class="newsletter-signup__header">
    {panel ? (
      <h2 id={`newsletter-title-${source}`}>{copy.panelTitle}</h2>
    ) : (
      <>
        <p class="eyebrow">{copy.cta.kicker}</p>
        <h2 id={`newsletter-title-${source}`}>{copy.cta.title}</h2>
        <p>{copy.cta.description}</p>
      </>
    )}
  </header>
  <form class="newsletter-form" data-newsletter-form novalidate>
    <label>
      <span>{copy.email}</span>
      <input name="email" type="email" autocomplete="email" maxlength="254" required />
    </label>
    <label class="honeypot" hidden>Company<input name="company" tabindex="-1" autocomplete="off" /></label>
    <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-action="newsletter_subscribe" data-theme="auto" data-size="flexible" data-appearance="interaction-only"></div>
    <div class="newsletter-form__action">
      <button class="button" type="submit" data-submit-label={copy.submit} data-loading-label={copy.loading}>{copy.submit}</button>
      <p>{copy.privacy}</p>
    </div>
    <p class="form-status" data-newsletter-status role="status" aria-live="polite"></p>
  </form>
</section>

<script>
  interface NewsletterCopy
  {
    readonly submit: string;
    readonly loading: string;
    readonly subscribed: string;
    readonly error: string;
    readonly invalidEmail: string;
    readonly rateLimited: string;
    readonly verification: string;
    readonly verificationExpired: string;
  }

  interface TurnstileApi
  {
    reset: (element?: HTMLElement) => void;
  }

  declare global
  {
    interface Window
    {
      turnstile?: TurnstileApi;
    }
  }

  ensureTurnstileScript();

  for (const root of document.querySelectorAll<HTMLElement>("[data-newsletter-root]"))
  {
    initializeNewsletter(root);
  }

  function initializeNewsletter(root: HTMLElement): void
  {
    if (root.dataset.initialized === "true")
    {
      return;
    }

    root.dataset.initialized = "true";
    const form = root.querySelector<HTMLFormElement>("[data-newsletter-form]");
    const copy = JSON.parse(root.dataset.copy ?? "{}") as NewsletterCopy;

    form?.addEventListener("submit", (event) =>
    {
      event.preventDefault();
      void submitNewsletterForm(root, form, copy);
    });

  }

  async function submitNewsletterForm(
    root: HTMLElement,
    form: HTMLFormElement,
    copy: NewsletterCopy,
  ): Promise<void>
  {
    const emailInput = form.elements.namedItem("email");
    const turnstileInput = form.querySelector<HTMLInputElement>("input[name='cf-turnstile-response']");
    const submitButton = form.querySelector<HTMLButtonElement>("button[type='submit']");
    const status = form.querySelector<HTMLElement>("[data-newsletter-status]");

    if (!(emailInput instanceof HTMLInputElement) || submitButton === null || status === null)
    {
      return;
    }

    delete status.dataset.status;

    if (!emailInput.checkValidity())
    {
      status.textContent = copy.invalidEmail;
      emailInput.focus();
      return;
    }

    if (turnstileInput === null || turnstileInput.value === "")
    {
      status.textContent = copy.verification;
      return;
    }

    const formData = new FormData(form);
    submitButton.disabled = true;
    submitButton.textContent = submitButton.dataset.loadingLabel ?? copy.loading;
    status.textContent = "";

    try
    {
      const response = await fetch("/api/newsletter/subscriptions", {
        method: "POST",
        headers: { "Content-Type": "application/json", Accept: "application/json" },
        body: JSON.stringify({
          email: formData.get("email"),
          locale: root.dataset.locale,
          source: root.dataset.source,
          sourcePath: window.location.pathname,
          consentVersion: root.dataset.consentVersion,
          turnstileToken: turnstileInput.value,
          company: formData.get("company"),
        }),
      });
      const result = await response.json() as { readonly error?: string };

      if (!response.ok)
      {
        resetTurnstile(form);

        if (result.error === "turnstile_failed")
        {
          status.textContent = copy.verificationExpired;
          return;
        }

        if (result.error === "rate_limited")
        {
          status.textContent = copy.rateLimited;
          return;
        }

        throw new Error("Newsletter subscription failed");
      }

      form.reset();
      status.textContent = copy.subscribed;
      status.dataset.status = "success";
      resetTurnstile(form);
    }
    catch
    {
      status.textContent = copy.error;
    }
    finally
    {
      submitButton.disabled = false;
      submitButton.textContent = submitButton.dataset.submitLabel ?? copy.submit;
    }
  }

  function resetTurnstile(form: HTMLFormElement): void
  {
    window.turnstile?.reset(form.querySelector<HTMLElement>(".cf-turnstile") ?? undefined);
  }

  function ensureTurnstileScript(): void
  {
    const source = "https://challenges.cloudflare.com/turnstile/v0/api.js";

    if (document.querySelector(`script[src='${source}']`) !== null)
    {
      return;
    }

    const script = document.createElement("script");
    script.src = source;
    script.async = true;
    script.defer = true;
    document.head.append(script);
  }

</script>
